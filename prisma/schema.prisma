// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  TRIAL
  PRO
  ENTERPRISE
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  FAILED
}

enum ConnectionStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum CampaignStatus {
  PENDING
  PROCESSING
  SENDING
  DONE
  PAUSED
  FAILED
}

enum HandoverStatus {
  ACTIVE
  INACTIVE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type       String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  instances           Instance[]
  contacts            Contact[]
  campaigns           Campaign[]
  messageLogs         MessageLog[]
  subscription        Subscription?

  plan                PlanType   @default(TRIAL)
  geminiKey            String?
  credits             Int       @default(1000)
  dailyMessageLimit   Int       @default(100)
  stripeCustomerId     String?

  aiEnabled           Boolean  @default(true)
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  stripeSubId     String?
  status          String   @default("active")
  plan            String   @default("trial")
  currentPeriodEnd DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Instance {
  id              String        @id @default(cuid())
  name            String        @unique
  sessionId       String?
  apiKey          String?
  qrCode         String?       @db.Text
  qrCodeUrl       String?
  status         InstanceStatus @default(DISCONNECTED)
  lastConnection DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  userId          String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts       Contact[]
  messageLogs    MessageLog[]
  chats          Chat[]
  campaigns      Campaign[]
}

model Contact {
  id              String   @id @default(cuid())
  name            String
  phone           String   @unique
  email           String?
  tags            String[] @default([])
  notes           String?  @db.Text
  aiEnabled       Boolean  @default(true)
  isBlacklisted  Boolean  @default(false)
  isHandoverActive HandoverStatus @default(INACTIVE)
  lastMessageAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  instanceId     String
  instance       Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  userId         String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageLogs   MessageLog[]
  chats         Chat[]
}

model Chat {
  id              String           @id @default(cuid())
  jid              String           @unique
  name             String?
  isGroup          Boolean          @default(false)
  aiEnabled        Boolean          @default(true)
  isHandoverActive HandoverStatus   @default(INACTIVE)
  lastMessageAt   DateTime?
  unreadCount    Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  instanceId     String
  instance      Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  contactId     String?
  contact       Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  messages      Message[]
}

model Message {
  id              String        @id @default(cuid())
  keyId           String?       @unique
  keyRemoteJid    String?
  keyFromMe       Boolean?
  keyParticipant  String?
  pushName        String?
  message         Json?
  messageType     String?
  timestamp       Int            @default(0)
  status          ConnectionStatus @default(SENT)
  isDeleted       Boolean        @default(false)
  createdAt      DateTime       @default(now())

  chatId         String
  chat          Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Campaign {
  id              String        @id @default(cuid())
  name            String
  messageTemplate String        @db.Text
  status          CampaignStatus @default(PENDING)
  totalRecipients Int          @default(0)
  sentCount       Int          @default(0)
  failedCount     Int          @default(0)
  successRate    Float        @default(0)
  
  baseDelay      Int          @default(30)
  randomDelay   Int          @default(30)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  userId         String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  instanceId    String
  instance     Instance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  messageLogs   MessageLog[]
}

model MessageLog {
  id              String          @id @default(cuid())
  phone           String
  message        String         @db.Text
  status         ConnectionStatus @default(SENT)
  errorCode      String?
  errorMessage  String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime @default(now())

  instanceId    String
  instance     Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  contactId    String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  campaignId   String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                    String   @id @default(cuid())
  globalGeminiKey       String?
  globalEvolutionApiKey String?
  evolutionApiUrl      String   @default("http://localhost:8080")
  sleepingHoursStart   Int      @default(23)
  sleepingHoursEnd     Int      @default(7)
  baseDelay            Int      @default(30)
  maxRetries           Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ApiLog {
  id              String   @id @default(cuid())
  endpoint        String
  method          String
  requestBody     String?  @db.Text
  responseBody   String?  @db.Text
  statusCode     Int?
  errorMessage   String?
  instanceName   String?
  userId        String?
  duration      Int?
  createdAt     DateTime @default(now())
}